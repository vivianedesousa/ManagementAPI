  "item": [
    {
      "name": "Menu Items",
      "description": "Operações CRUD para itens de cardápio",
      "item": [
        {
          "name": "Create Menu Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('menuItemId', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Margherita\",\n  \"description\": \"Pizza clássica com mozzarella e tomate\",\n  \"price\": 45.90,\n  \"dineInOnly\": false,\n  \"photoPath\": \"/images/pizza.jpg\",\n  \"restaurantId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/menu-items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu-items"
              ]
            },
            "description": "Criar um novo item de cardápio"
          },
          "response": []
        },
        {
          "name": "Get Menu Items by Restaurant",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/menu-items/restaurant/{{restaurantId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu-items",
                "restaurant",
                "{{restaurantId}}"
              ]
            },
            "description": "Listar todos os itens de um restaurante"
          },
          "response": []
        },
        {
          "name": "Get Menu Item by Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/menu-items/{{menuItemId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu-items",
                "{{menuItemId}}"
              ]
            },
            "description": "Obter detalhes de um item de cardápio"
          },
          "response": []
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Premium\",\n  \"description\": \"Pizza premium com ingredientes selecionados\",\n  \"price\": 65.90,\n  \"dineInOnly\": true,\n  \"photoPath\": \"/images/pizza-premium.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/menu-items/{{menuItemId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu-items",
                "{{menuItemId}}"
              ]
            },
            "description": "Atualizar um item de cardápio"
          },
          "response": []
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/menu-items/{{menuItemId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "menu-items",
                "{{menuItemId}}"
              ]
            },
            "description": "Remover um item de cardápio"
          },
          "response": []
        }
      ]
    },
